# ========================================================================
# Mastermind 智囊团 · 环境变量示例
#
# 本地开发：复制此文件为 .env.local（已被 .gitignore 排除），填入真实值
# 生产环境：在 Vercel Dashboard → Settings → Environment Variables 配置
# ========================================================================

# ---- DashScope (Qwen) API 配置 ----

# 阿里云百炼 API Base URL（OpenAI 兼容模式）
DASHSCOPE_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"

# 阿里云 API Key（格式形如 sk-xxxxxxxx...）
# 获取地址: https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=""

# ---- 模型选择 ----
#
# 2026-04 末实测可用且 council 单场跑得通的模型：
#   qwen3.6-max-preview        ⭐ 推荐  · 100 万 token 免费 · 2026-07-20 到期
#   qwen3.5-plus / qwen3.5-plus-2026-02-15
#                              · 各 100 万 token · 2026-05-18 到期
#   deepseek-v4-pro / deepseek-v4-flash
#                              · 不同 family，~250s 较慢但内容好 · 2026-07-24 到期
#
# ⚠️  Qwen 3.x 默认开启 reasoning（thinking）阶段，会先吐 ~30s thinking 才出 content。
#     api/council.ts + api/intake-clarify.ts 已传 `enable_thinking: false` 关闭，
#     使响应在 Vercel edge 60s maxDuration 内完成。
#
# ⚠️  `qwen3-max` / `qwen3-max-preview` / `qwen-plus` / `qwen-max` / `qwen-turbo`
#     这些"传统系列"在 2026-04-29 已被实测确认免费额度全部耗尽（"仅免费额度"模式下 403）。
#     若账户开启"仅免费额度"保护：到 https://bailian.console.aliyun.com/
#     关闭"免费额度用完即停"开关可切按量付费；或换用上面 ⭐ 列表里的新模型。
#
# 服务端选哪个 model 由这三个 env 变量决定（council 用 SYNTHESIZER）：

# 军师圆桌用（council 单次调用同时演 N 位人物 + 输出结构化 JSON，质量瓶颈）
MODEL_SYNTHESIZER="qwen3.6-max-preview"

# 军师发言用（当前 council 架构没用，留作将来切回 N 次调用时的预留）
MODEL_ADVISOR="qwen3.6-max-preview"

# 主持人追问用（MVP 已 bypass，但 intake-clarify 仍走此模型，可换轻量）
MODEL_HOST="qwen3.6-max-preview"
