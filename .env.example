# ========================================================================
# Mastermind 智囊团 · 环境变量示例
#
# 本地开发：复制此文件为 .env.local（已被 .gitignore 排除），填入真实值
# 生产环境：在 Vercel Dashboard → Settings → Environment Variables 配置
# ========================================================================

# ---- DashScope (Qwen) API 配置 ----

# 阿里云百炼 API Base URL（OpenAI 兼容模式）
DASHSCOPE_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"

# 阿里云 API Key（格式形如 sk-xxxxxxxx...）
# 获取地址: https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=""

# ---- 模型选择 ----
#
# 2026-04 实测可用名称：
#   qwen3-max / qwen3-max-preview / qwen3-max-2025-09-23 / qwen3-max-2026-01-23
#     → 每个变体各 100 万 token 免费额度（共 400 万）
#   qwen-turbo → 100 万 token 免费额度（轻量任务够用）
#   qwen-plus / qwen-max → 传统系列，免费额度通常先耗尽；耗尽后免费账户被"仅免费额度"开关拦截
#
# ⚠️  `qwen3-plus` 不存在（spec v5.4 前误用）。
# 若账户开启"仅免费额度"保护，且所选模型免费额度用完，API 会 403——
#   到 https://bailian.console.aliyun.com/ 关闭"免费额度用完即停"开关可切换到按量付费。

# 军师发言用（调用 N 次，N = 选中军师数量，占主要成本）
MODEL_ADVISOR="qwen3-max"

# Analyst 校验归纳用（调用 1 次，推理质量瓶颈）
MODEL_SYNTHESIZER="qwen3-max"

# 主持人追问用（MVP 已 bypass，但仍保留环境变量供将来切回）
MODEL_HOST="qwen3-max"
