# ========================================================================
# Mastermind 智囊团 · 环境变量示例
#
# 本地开发：复制此文件为 .env.local（已被 .gitignore 排除），填入真实值
# 生产环境：在 Vercel Dashboard → Settings → Environment Variables 配置
# ========================================================================

# ---- DashScope (Qwen) API 配置 ----

# 阿里云百炼 API Base URL（OpenAI 兼容模式）
DASHSCOPE_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"

# 阿里云 API Key（格式形如 sk-xxxxxxxx...）
# 获取地址: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=""

# ---- 模型选择（可覆盖为更便宜/更强的型号）----
#
# DashScope OpenAI 兼容端点当前可用模型名参考：
#   qwen-max / qwen-plus / qwen-turbo / qwen-long
#   qwen3-max-preview 等带后缀的具体版本
# （2026-04 smoke 测时发现 "qwen3-plus" / "qwen3-max" 返回 404，
#  正确命名是去 "3"。如果账号开启了"仅免费额度"模式且额度耗尽，
#  除 qwen-turbo 外其他模型会 403——需要去 DashScope 管理台关闭该模式）

# 军师发言用（调用 N 次，N = 选中军师数量，占主要成本）
MODEL_ADVISOR="qwen-plus"

# Analyst 校验归纳用（调用 1 次，推理质量瓶颈）
MODEL_SYNTHESIZER="qwen-max"

# 主持人追问用（调用 0-1 次，轻量判断）
MODEL_HOST="qwen-plus"
